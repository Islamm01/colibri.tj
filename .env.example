# ANJIR — environment variables
# Copy this to .env.local and fill in your Supabase project values.

# Supabase project URL (from Supabase dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (SERVER ONLY — never expose to browser)
# Required in Slice 2+ for order creation and admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session signing secret (used to sign the soft-account cookie).
# Generate one with: openssl rand -hex 32
# In production this MUST be set. In dev a fallback is used if missing.
SESSION_SECRET=replace-me-with-a-long-random-string-from-openssl-rand-hex-32

# ===== Geocoding (address autocomplete + reverse geocode) =====
# Provider: 'yandex' | '2gis' | 'osm'  (default 'osm' — free, no key needed)
# To enable real Tajikistan address autocomplete with house numbers,
# register a key and set the provider:
GEOCODER_PROVIDER=osm
# YANDEX_GEOCODER_KEY=your-yandex-geocoder-api-key
# TWOGIS_KEY=your-2gis-api-key
